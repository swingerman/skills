# ~/.config/ghostty/config — bundled by zenify-my-terminal
# Ghostty config format: simple key = value, one per line. Reload: Cmd-Shift-,

# --- Font ------------------------------------------------------------------
font-family = JetBrainsMono Nerd Font
font-size = 14

# --- Theme (run `ghostty +list-themes` to browse) --------------------------
theme = tokyonight_moon

# --- Window ----------------------------------------------------------------
window-padding-x = 10
window-padding-y = 10
window-decoration = true

# --- macOS ------------------------------------------------------------------
macos-option-as-alt = left
macos-titlebar-style = transparent
macos-titlebar-proxy-icon = hidden

# --- Splits and tabs (Ghostty defaults are mostly fine; a couple of tweaks) -
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+w=close_surface
keybind = cmd+enter=toggle_split_zoom

# Cursor
cursor-style = block
cursor-style-blink = false

# Scrollback
scrollback-limit = 100000
